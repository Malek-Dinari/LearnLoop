# ──────────────────────────────────────────────────────────────────────────────
# LearnLoop backend configuration
# Copy this file to .env and fill in the values.
# All settings have defaults; only override what you need.
# ──────────────────────────────────────────────────────────────────────────────

# ─── LLM provider ─────────────────────────────────────────────────────────────
# "ollama" for local dev, "groq" for cloud/production
LLM_PROVIDER=ollama

# Ollama (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:1.7b

# Groq (used when LLM_PROVIDER=groq)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_REQUEST_TIMEOUT=30.0

# ─── File uploads ─────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
# Set USE_DATABASE=false to keep everything in memory (no PostgreSQL needed)
USE_DATABASE=false
DATABASE_URL=postgresql+asyncpg://learnloop:learnloop@localhost:5432/learnloop
DB_ECHO=false

# ─── Cache ────────────────────────────────────────────────────────────────────
# "memory" for local dev, "redis" for Docker/production
CACHE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_SECONDS=1800

# ─── LLM performance tuning ───────────────────────────────────────────────────
QUIZ_BATCH_SIZE=2
LLM_REQUEST_TIMEOUT=60.0
LLM_NUM_CTX=8192
LLM_MAX_PROMPT_CHARS=8000
