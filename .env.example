# LLM provider: "ollama" (local) or "groq" (cloud)
LLM_PROVIDER=ollama

# Ollama settings (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen3:1.7b

# Groq settings (used when LLM_PROVIDER=groq)
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_REQUEST_TIMEOUT=30.0

# App settings
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
DEFAULT_NUM_QUESTIONS=10
CORS_ORIGINS=http://localhost:3000

# LLM performance tuning
LLM_NUM_CTX=8192
LLM_NUM_PREDICT_JSON=1500
LLM_NUM_PREDICT_TEXT=1024
LLM_REQUEST_TIMEOUT=45.0
LLM_MAX_PROMPT_CHARS=6000
QUIZ_BATCH_SIZE=1

# Caching
CACHE_TTL_SECONDS=1800
